              "value": "={{$json.body?.goal || $json.goal || 'research-brief'}}",
              "type": "string"
            },
            {
              "name": "feedback",
              "value": "={{$json.body?.feedback || $json.feedback || '리스크/기회 중심으로 분석'}}",
              "type": "string"
            }
          ]
        }
      },
      "id": "SetInput",
      "name": "Set Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        390,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const arr = $json.items || [];\nif (!Array.isArray(arr) || arr.length === 0) throw new Error('body.items 배열이 필요합니다.');\nreturn arr.map((x, idx) => ({ json: { idx, raw: x, targetLanguage: $json.targetLanguage, goal: $json.goal, feedback: $json.feedback } }));"
      },
      "id": "Explode",
      "name": "Explode Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        320
      ]
    },
    {
      "parameters": {
        "jsCode": "const v = $json.raw;\nconst isUrl = typeof v === 'string' && /^https?:\\/\\//i.test(v);\nreturn [{ json: { ...$json, type: isUrl ? 'url' : 'text', url: isUrl ? v : '', text: isUrl ? '' : String(v) } }];"
      },
      "id": "Classify",
      "name": "Classify Source",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        810,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.type}}",
              "operation": "equals",
              "value2": "url"
            }
          ]
        }
      },
      "id": "IfURL",
      "name": "If URL",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
